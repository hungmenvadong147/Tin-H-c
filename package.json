{
  "name": "personal-learning-website",
  "version": "2.0.0",
  "description": "Website học tập cá nhân với quản trị nội dung - TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/server.js\"",
    "build:frontend": "tsc --project tsconfig.frontend.json",
    "watch:frontend": "tsc --project tsconfig.frontend.json --watch"
  },
  "keywords": ["education", "learning", "website", "typescript"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^2.0.0-rc.4",
    "sqlite3": "^5.1.6",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.3",
    "nodemon": "^3.0.1"
  }
}
